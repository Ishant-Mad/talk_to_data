# Data directory configuration
DATA_DIR=./data
PROFILE_PATH=./data/data_profile.json

# ==========================================
# LLM Provider Configuration
# Supported providers: "groq", "github", "openrouter"
# ==========================================
LLM_PROVIDER=openrouter

# ==========================================
# Groq Setup (Fastest inference)
# Get your API key from: https://console.groq.com/keys
# ==========================================
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# GitHub Copilot Models Setup
# For GitHub Models accessed via personal access token
# ==========================================
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL=Ministral-3B

# ==========================================
# OpenRouter Setup (Recommended for many model choices)
# Supports MULTIPLE API KEYS for load balancing/rate limits!
# Provide a comma-separated list of keys in quotes.
# ==========================================
OPENROUTER_API_KEYS="key1,key2,key3"
# You can specify any free or paid model on OpenRouter:
OPENROUTER_MODEL=openai/gpt-oss-120b:free
